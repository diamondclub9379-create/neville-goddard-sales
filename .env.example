# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Absolute public URL of this deployment (no trailing slash).
# Used to build the Google OAuth redirect_uri.
# Local dev:   http://localhost:3000
# Production:  https://shop.example.com
PUBLIC_BASE_URL=http://localhost:3000

# ─── Session / JWT ──────────────────────────────────────────────────────────
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── Database (MySQL / TiDB Cloud Serverless) ───────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# ─── Google OAuth ───────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {PUBLIC_BASE_URL}/api/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Admin promotion ────────────────────────────────────────────────────────
# Comma-separated list of Google account emails that are auto-admin on login.
# Example: coachwanchai@gmail.com,another@example.com
ADMIN_EMAILS=

# ─── Email (Resend) — order confirmations + owner notifications ─────────────
# https://resend.com/api-keys
RESEND_API_KEY=
# Where owner notifications (new orders, etc.) are sent:
OWNER_EMAIL=
# Verified sender. Until you verify a domain on Resend, use: "Name <onboarding@resend.dev>"
NOTIFICATION_FROM_EMAIL=Neville Books <onboarding@resend.dev>

# ─── Stripe (credit-card payments) ──────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get this from the Stripe CLI or dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ─── Google Analytics 4 ─────────────────────────────────────────────────────
# Measurement ID from analytics.google.com (Admin → Data Streams → Web).
# Format: G-XXXXXXXXXX. When unset, the analytics code becomes a no-op.
# IMPORTANT: must be prefixed with VITE_ so Vite exposes it to the client.
VITE_GA_MEASUREMENT_ID=

# ─── S3 storage (payment slip uploads) ──────────────────────────────────────
# Works with AWS S3, Cloudflare R2, Backblaze B2, or MinIO.
# For AWS S3: leave S3_ENDPOINT empty and set S3_REGION (e.g. ap-southeast-1).
# For R2:     S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com  S3_REGION=auto
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional — if you expose the bucket through a CDN or public URL base, set it here
# so uploaded files return a stable public URL instead of a 7-day pre-signed URL.
# Example: https://cdn.example.com or https://pub-xxx.r2.dev
S3_PUBLIC_URL_BASE=
